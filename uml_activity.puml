@startuml OPTIQ_Activity
skinparam ActivityBorderColor #2E75B6
skinparam ActivityBackgroundColor #EAF4FB
skinparam ActivityDiamondBackgroundColor #FFF9E6
skinparam ActivityDiamondBorderColor #D4A017
skinparam ArrowColor #2E75B6
skinparam NoteBackgroundColor #FFFBE6
skinparam NoteBorderColor #D4A017
skinparam PartitionBorderColor #2E75B6
skinparam PartitionBackgroundColor #F5FAFF

title OPTIQ DSS — Activity Diagram (Optimisation & FOPDT Tracking Lifecycle)

start

partition "Live Monitoring" {
  :Receive sensor readings via WebSocket\n(DCS/SCADA → FastAPI → React);
  :XGBoost Surrogate predicts\nenergy, purity, butane;
  :Display live KPI cards on Dashboard;
  if (Outlier detected?) then (yes)
    :Raise Sensor Alert\n(log to DB, show badge);
  else (no)
  endif
}

partition "Staleness Check" {
  if (Recommendation exists AND\nage > threshold OR drift > 10%?) then (stale)
    :Show "⚡ Update Recommendation"\n(orange pulsing button);
  else (fresh or no recommendation)
  endif
}

partition "Request Optimisation (DE)" {
  :Operator clicks "Update Recommendation";
  :POST /recommendations/optimize\n{current_state, base_readings, column_tag};
  :Load SP config bounds from DistillationColumn.config;
  fork
    :XGBoost baseline prediction\n(current KPIs);
  fork again
    :DE Optimiser iterations\n(population mutation, crossover, selection);
    note right
      Objective: min w1*E + w2*(1-P) + w3*ΔSP_penalty
      Bounds: SetpointConfig.lo / hi per tag
    end note
  end fork
  :Save OptimizationResult to DB\n(status="computed");
  :Return recommended_setpoints,\nenergy_savings_pct, purity_improvement_pct;
  :Display Recommendation panel\n(current vs recommended, KPI deltas, SP table);
}

partition "Apply Recommendation + FOPDT" {
  :Operator reviews recommendation;
  if (Accept recommendation?) then (yes)
    :POST /recommendations/{id}/apply;
    :Mark OptimizationResult applied=True in DB;
    :FOPDT Simulator computes process response:
    repeat
      :horizon = next in [+5 min, +15 min, +30 min];
      :settling(t) = 1 − exp(−(t − θ) / τ);
      :OP_blend = current + settling × (rec − current);
      :PV = pv_nom + K × (OP_blend − 50%);
      :XGBoost predicts energy/purity at blended OP;
    repeat while (more horizons?) is (yes)
    -> no;
    :Return List[SimulationStep] with predicted tag_values;
    :Display FOPDT panel:\n  +5 min / +15 min / +30 min cards\n  "verify on DCS" for each tag;
    :Browser schedules setTimeout per horizon\n(time_s × 1000 ms);
  else (reject)
    :Request stays "computed"\nOperator can re-request;
    stop
  endif
}

partition "Automatic Process Tracking" {
  fork
    :setTimeout fires at +5 min;
  fork again
    :setTimeout fires at +15 min;
  fork again
    :setTimeout fires at +30 min;
  end fork

  :Read currentTagsRef\n(live DCS values from WebSocket);
  :POST /recommendations/{id}/tracking\n{actual_tag_values};
  :ProcessTracker interpolates predicted PV\nat elapsed_s from SimulationSteps;
  :Compute deviation_pct per PV tag:
  note right
    deviation_pct = |actual − predicted| / |predicted| × 100
  end note

  if (All deviations ≤ 5%?) then (yes — tracking OK)
    :Update horizon card:\n  green border\n  show actual value (strike predicted)\n  "✓ DCS tracking · max dev X%";
    :Button stays "⚡ Update Recommendation";
    if (All 3 horizons complete and all OK?) then (yes)
      :Process followed expected trajectory\nNo action needed;
      stop
    else (more horizons pending)
    endif
  else (no — deviation detected)
    :Update horizon card:\n  red border\n  show actual vs predicted\n  "⚠ X% deviation on [tags]";
    :Show top-level red banner:\n  "⚠ Process deviated from expected trajectory\n   Recompute recommended";
    :Button changes to:\n  "⚠ Recompute (conditions changed)";
    if (Operator chooses to recompute?) then (yes)
      :Clear applied state & tracking results;
      :POST /recommendations/optimize\n(new cycle with current live readings);
      note right
        Recompute re-enters the DE optimisation
        loop with updated process conditions
      end note
      -> (back to Request Optimisation);
    else (ignore / monitor)
      :Operator continues monitoring\nwaiting for subsequent horizon check;
    endif
  endif
}

stop

@enduml
